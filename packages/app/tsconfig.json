{
  "compilerOptions": {
    "target": "ESNext",
    "module": "preserve",
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src"],
  "lib": ["ESNext", "DOM", "DOM.Iterable"]
}
